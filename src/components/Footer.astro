---
// Footer component
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang?: keyof typeof languages;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<footer class="bg-tertiary text-white py-16 border-t border-white/10 relative z-[70]">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-2 space-y-4">
        <a href={currentLang === 'fr' ? '/' : `/${currentLang}/`} class="flex items-center gap-2">
          <img src="/logo.png" alt="FIABILIS.ai Logo" class="h-8 w-auto object-contain" />
        </a>
        <p class="text-white/60 text-sm max-w-sm font-normal leading-relaxed">
          {t('hero.subtitle')}
        </p>
      </div>

      <div>
        <h4 class="font-bold text-white text-sm mb-4 uppercase tracking-wider">{t('nav.solutions')}</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a class="hover:text-white transition-colors" href="#solutions">MyVM</a></li>
          <li><a class="hover:text-white transition-colors" href="#solutions">App Chantier</a></li>
          <li><a class="hover:text-white transition-colors" href="#solutions">Expertis</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-white text-sm mb-4 uppercase tracking-wider">{t('nav.about')}</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a class="hover:text-white transition-colors" href="#expertise">{t('nav.about')}</a></li>
          <li><a class="hover:text-white transition-colors" href="#personas">{t('nav.solutions')}</a></li>
          <li><a class="hover:text-white transition-colors" href="#trust">{t('trust.title')}</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-white/50">
      <div>© {new Date().getFullYear()} FIABILIS.ai. {t('footer.rights')}</div>
      <div class="flex gap-6">
        <a class="hover:text-white transition-colors" href="#">{t('footer.privacy')}</a>
        <a class="hover:text-white transition-colors" href="#">{t('footer.terms')}</a>
        <a class="hover:text-white transition-colors" href="#">{t('footer.cookies')}</a>
      </div>
    </div>
  </div>
</footer>
