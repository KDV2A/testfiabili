---
// Hero section block (Block 1)
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang?: keyof typeof languages;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<section class="relative bg-white z-10 py-40 md:py-60 min-h-screen flex flex-col items-center justify-center overflow-hidden stacked-block group/hero" id="hero">
  <!-- Subtle Base Grid Pattern -->
  <div class="absolute inset-0 pointer-events-none z-0 opacity-15 bg-[linear-gradient(to_right,#031a4b0d_1px,transparent_1px),linear-gradient(to_bottom,#031a4b0d_1px,transparent_1px)] bg-[size:40px_40px]"></div>

  <!-- High-Performance Interactive Cursor Grid Spotlight -->
  <div 
    id="hero-grid-spotlight" 
    class="absolute inset-0 pointer-events-none z-0 transition-opacity duration-500 opacity-0 group-hover/hero:opacity-100"
    style="
      background-image: linear-gradient(to right, rgba(182, 0, 90, 0.3) 1px, transparent 1px), linear-gradient(to bottom, rgba(3, 26, 75, 0.3) 1px, transparent 1px);
      background-size: 40px 40px;
      -webkit-mask-image: radial-gradient(480px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);
      mask-image: radial-gradient(480px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);
      will-change: transform;
    "
  >
  </div>

  <!-- Spotlight Ambient AI Glow -->
  <div 
    id="hero-spotlight-glow" 
    class="absolute inset-0 pointer-events-none z-0 transition-opacity duration-500 opacity-0 group-hover/hero:opacity-100"
    style="
      background: radial-gradient(520px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(231, 49, 124, 0.13) 0%, rgba(3, 26, 75, 0.04) 50%, transparent 80%);
      will-change: transform;
    "
  >
  </div>

  <div class="ai-orb w-[500px] h-[500px] -top-20 -left-20 pointer-events-none"></div>

  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop grid lg:grid-cols-3 gap-16 items-center relative z-10 stacked-content w-full">
    <div class="lg:col-span-2 space-y-8 gsap-reveal lg:-translate-y-16">
      <h1 class="font-poppins font-semibold text-4xl sm:text-5xl lg:text-6xl leading-[1.15] text-primary tracking-tight">
        {t('hero.title_pre')}<span class="gradient-text font-bold">{t('hero.title_gradient')}</span>{t('hero.title_post')}
      </h1>
      <p class="font-poppins font-normal text-base md:text-lg text-on-surface-variant max-w-2xl leading-relaxed">
        {t('hero.subtitle')}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 items-stretch sm:items-start pt-2">
        <a 
          href="#cta" 
          class="btn-gradient px-8 py-4 rounded-full text-white font-poppins font-bold text-sm md:text-base w-full sm:w-auto border-t border-white/40 shadow-lg shadow-secondary/40 flex items-center justify-center text-center cursor-pointer" 
          style="background-image: linear-gradient(to bottom, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 50%), var(--gradient-3); box-shadow: inset 0 1px 1px rgba(255,255,255,0.4);"
        >
          {t('hero.btn_primary')}
        </a>
        <a 
          href="#solutions" 
          class="bg-white border-2 border-primary text-primary px-8 py-4 rounded-full font-poppins font-bold text-sm md:text-base hover:bg-surface-container-low transition-all shadow-md w-full sm:w-auto flex items-center justify-center gap-2 text-center cursor-pointer"
        >
          {t('hero.btn_secondary')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <div class="mt-12 flex flex-wrap gap-4 pt-4">
        <div class="flex items-center gap-3 px-6 py-3 rounded-full bg-surface-container-low border border-outline-variant/20 shadow-sm">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">history</span>
          <span class="font-poppins font-medium text-sm text-on-surface">{t('hero.badge1')}</span>
        </div>
        <div class="flex items-center gap-3 px-6 py-3 rounded-full bg-surface-container-low border border-outline-variant/20 shadow-sm">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">public</span>
          <span class="font-poppins font-medium text-sm text-on-surface">{t('hero.badge2')}</span>
        </div>
        <div class="flex items-center gap-3 px-6 py-3 rounded-full bg-surface-container-low border border-outline-variant/20 shadow-sm">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">verified_user</span>
          <span class="font-poppins font-medium text-sm text-on-surface">{t('hero.badge3')}</span>
        </div>
      </div>
    </div>

    <div class="lg:col-span-1 relative flex justify-center lg:translate-y-20 pt-10 lg:pt-0">
      <div class="relative w-full max-w-md">
        <div class="absolute -inset-4 bg-gradient-to-r from-primary/10 to-secondary/10 rounded-full blur-2xl z-0"></div>
        <img 
          alt="AI Infrastructure 3D" 
          class="w-full h-auto drop-shadow-2xl relative z-10 object-contain" 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBkolc7rBJHZ6oVc37woDHYDLaQRuEJxqmfVNSsk3V890qIM-Fp5569a-X-8d_rYCRx1N0DOoGzd9PFrVyS8CdQpZuAieqqlELKeh-F4XLd6kEV06M4qcP9AuTp0yNjOCqfvQOj-lWS5zmbtF1P0k5KCZuSxwykprrPFJnOkRu-IYOld0PHk2lYO5h6-STypJXQKaLO2mSTrOyWKhdnWX7fsDRqxvkj5otSUiEO1bcxGKjy4FM5Z5gAlPSaBTTf0nob5QdP20CYKLFP"
        />
      </div>
    </div>
  </div>
</section>

<script>
  const hero = document.getElementById('hero');
  const gridSpotlight = document.getElementById('hero-grid-spotlight');
  const spotlightGlow = document.getElementById('hero-spotlight-glow');

  if (hero && gridSpotlight && spotlightGlow) {
    let mouseX = 0;
    let mouseY = 0;
    let ticking = false;

    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;

      if (!ticking) {
        requestAnimationFrame(() => {
          gridSpotlight.style.setProperty('--mouse-x', `${mouseX}px`);
          gridSpotlight.style.setProperty('--mouse-y', `${mouseY}px`);
          spotlightGlow.style.setProperty('--mouse-x', `${mouseX}px`);
          spotlightGlow.style.setProperty('--mouse-y', `${mouseY}px`);
          ticking = false;
        });
        ticking = true;
      }
    });
  }
</script>
