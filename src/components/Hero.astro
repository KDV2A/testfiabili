---
// Hero.astro
---

<section class="relative bg-gradient-hero text-on-primary overflow-hidden py-24 md:py-40">
  <!-- Brand Decorative Arcs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden opacity-50">
    <svg class="absolute -top-20 -right-20 w-[120%] h-[140%] brand-arc-glow" fill="none" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
      <path d="M-100 800C150 750 450 500 1200 150" opacity="0.4" stroke="#e7317c" stroke-dasharray="1 10" stroke-linecap="round" stroke-width="4"></path>
      <path d="M-50 850C250 800 650 450 1300 200" stroke="#e95c40" stroke-linecap="round" stroke-width="2.5"></path>
      <path d="M0 900C350 850 750 500 1400 250" opacity="0.6" stroke="#ba1a1a" stroke-linecap="round" stroke-width="6"></path>
      <path d="M100 950C450 900 850 550 1500 300" stroke="#e7317c" stroke-linecap="round" stroke-width="1.5"></path>
    </svg>
  </div>
  <div class="relative max-w-container-max mx-auto px-margin-mobile md:px-gutter grid md:grid-cols-2 gap-16 items-center">
    <div class="space-y-10">
      <div class="inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-md px-5 py-2.5 rounded-full border border-white/20">
        <span class="material-symbols-outlined text-secondary-fixed-dim text-[18px]">auto_awesome</span>
        <span class="text-xs font-semibold uppercase tracking-[0.1em] text-white/90">L'IA au service de la conformité</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold leading-[1.1] tracking-tight font-display text-white">
        L'expertise payroll augmentée par <span class="text-transparent bg-clip-text bg-gradient-to-r from-secondary-fixed-dim to-brand-orange">l'Intelligence Artificielle</span>
      </h1>
      <p class="text-lg md:text-xl font-normal text-white/70 max-w-xl leading-relaxed">
        Fiabilis combine 30 ans de conseil haut de gamme avec 6 outils IA de pointe pour sécuriser vos cotisations et libérer votre potentiel humain.
      </p>
      <div class="flex flex-wrap gap-5 pt-4">
        <a class="bg-secondary text-white px-10 py-5 rounded-full font-semibold text-base hover:bg-button-hover transition-all shadow-2xl shadow-secondary/30 hover:-translate-y-1" href="#solutions">Découvrir nos solutions</a>
        <a class="bg-white/5 backdrop-blur-md text-white border border-white/20 px-10 py-5 rounded-full font-semibold text-base hover:bg-white/10 transition-all hover:-translate-y-1" href="#expertise">Consulter notre expertise</a>
      </div>
    </div>
    <!-- Visual Element: Interactive Card UI -->
    <div class="relative hidden lg:block group animate-float">
      <div class="absolute -inset-10 bg-gradient-to-tr from-secondary/20 to-primary/20 blur-[100px] opacity-40"></div>
      <div class="relative bg-white/5 border border-white/10 backdrop-blur-2xl rounded-[32px] p-10 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.5)]">
        <div class="flex items-center justify-between mb-12">
          <div class="flex gap-2.5">
            <div class="w-3.5 h-3.5 rounded-full bg-[#FF5F57]"></div>
            <div class="w-3.5 h-3.5 rounded-full bg-[#FEBC2E]"></div>
            <div class="w-3.5 h-3.5 rounded-full bg-[#28C840]"></div>
          </div>
          <div class="text-white/40 text-xs font-mono tracking-widest uppercase">system.ready_v4.2</div>
        </div>
        <div class="space-y-6">
          <div class="flex items-center gap-5 bg-white/5 p-6 rounded-2xl border border-white/10 transition-all hover:bg-white/10">
            <div class="w-12 h-12 rounded-xl bg-secondary flex items-center justify-center shadow-lg shadow-secondary/20">
              <span class="material-symbols-outlined text-white">psychology</span>
            </div>
            <div class="flex-1">
              <div class="h-2.5 w-28 bg-white/20 rounded-full mb-3"></div>
              <div class="h-2 w-56 bg-white/10 rounded-full"></div>
            </div>
            <span class="material-symbols-outlined text-green-400 text-3xl">check_circle</span>
          </div>
          <div class="flex items-center gap-5 bg-white/5 p-6 rounded-2xl border border-white/10 ml-12 transition-all hover:bg-white/10">
            <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center shadow-lg border border-white/10">
              <span class="material-symbols-outlined text-white">shield</span>
            </div>
            <div class="flex-1">
              <div class="h-2.5 w-36 bg-white/20 rounded-full mb-3"></div>
              <div class="h-2 w-48 bg-white/10 rounded-full"></div>
            </div>
          </div>
          <div class="flex items-center gap-5 bg-white/20 p-6 rounded-2xl border border-white/30 transform scale-[1.05] shadow-2xl transition-all">
            <div class="w-12 h-12 rounded-xl bg-secondary flex items-center justify-center shadow-lg">
              <span class="material-symbols-outlined text-white">chat_bubble</span>
            </div>
            <div class="flex-1">
              <div class="h-2.5 w-full bg-white/40 rounded-full mb-3"></div>
              <div class="h-2 w-3/4 bg-white/20 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
