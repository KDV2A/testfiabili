---
// Header component with i18n support and flag dropdown
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang?: keyof typeof languages;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<header class="top-0 left-0 right-0 z-[100] w-full flex justify-center px-margin-mobile md:px-margin-desktop py-4 pointer-events-none fixed">
  <div 
    class="w-full max-w-container-max flex items-center justify-between gap-4 md:gap-8 px-6 md:px-8 py-3 rounded-full backdrop-blur-2xl border border-white/20 shadow-2xl pointer-events-auto" 
    style="background: linear-gradient(135deg, rgba(3, 26, 75, 0.9) 0%, rgba(182, 0, 90, 0.8) 100%); box-shadow: rgba(255, 255, 255, 0.4) 0px 1px 1px inset, rgba(0, 0, 0, 0.2) 0px 20px 40px; min-height: 64px;"
  >
    <div class="flex items-center gap-6 md:gap-8">
      <a href={currentLang === 'fr' ? '/' : `/${currentLang}/`} class="flex items-center gap-2">
        <img src="/logo.png" alt="FIABILIS.ai Logo" class="h-7 md:h-8 w-auto object-contain" />
      </a>

      <nav class="hidden md:flex items-center gap-2">
        <a class="text-sm transition-all text-white font-medium px-4 py-1.5 hover:text-white/70 duration-300" href="#solutions">{t('nav.tools')}</a>
        <a class="text-sm transition-colors text-white font-medium px-4 py-1.5 hover:text-white/70 duration-300" href="#personas">{t('nav.solutions')}</a>
        <a class="text-sm transition-colors text-white font-medium px-4 py-1.5 hover:text-white/70 duration-300" href="#expertise">{t('nav.about')}</a>
        
        <div class="group relative">
          <button class="text-sm transition-colors text-white font-medium px-4 py-1.5 hover:text-white/70 duration-300 flex items-center gap-1 cursor-pointer">
            {t('nav.resources')} <span class="material-symbols-outlined text-sm group-hover:rotate-180 transition-transform duration-300">expand_more</span>
          </button>
          <div class="absolute top-full left-0 pt-6 w-64 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 pointer-events-none group-hover:pointer-events-auto group-hover:translate-y-1 z-50">
            <div class="p-6 flex flex-col gap-4 border border-white/10 shadow-2xl rounded-[32px] overflow-hidden backdrop-blur-3xl bg-[#1a2b4b]">
              <a class="text-white text-sm font-medium hover:text-white/80 transition-colors py-2 px-2 flex items-center justify-between" href="#trust">{t('nav.case_studies')}</a>
              <a class="text-white text-sm font-medium hover:text-white/80 transition-colors py-2 px-2 flex items-center justify-between" href="#trust">{t('nav.docs')}</a>
              <a class="text-white text-sm font-medium hover:text-white/80 transition-colors py-2 px-2 flex items-center justify-between" href="#cta">{t('nav.webinars')}</a>
            </div>
          </div>
        </div>
      </nav>
    </div>

    <div class="flex items-center gap-3">
      <div class="group relative hidden sm:flex items-center">
        <button class="text-sm transition-colors text-white font-medium px-4 py-1.5 hover:text-white/70 duration-300 flex items-center gap-2 cursor-pointer" aria-label="Langue">
          <span class="text-base">{languages[currentLang].flag}</span>
          <span class="uppercase text-xs font-bold tracking-wider">{currentLang}</span>
          <span class="material-symbols-outlined text-sm group-hover:rotate-180 transition-transform duration-300">expand_more</span>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-6 w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 pointer-events-none group-hover:pointer-events-auto group-hover:translate-y-1 z-50">
          <div class="p-6 flex flex-col gap-4 border border-white/10 shadow-2xl rounded-[32px] overflow-hidden backdrop-blur-3xl bg-[#1a2b4b]">
            <a class={`text-white text-sm font-medium hover:text-white/80 transition-colors py-2 px-2 flex items-center gap-3 ${currentLang === 'fr' ? 'font-bold text-secondary-fixed' : ''}`} href="/">
              <span class="text-base">🇫🇷</span> <span>Français</span>
            </a>
            <a class={`text-white text-sm font-medium hover:text-white/80 transition-colors py-2 px-2 flex items-center gap-3 ${currentLang === 'en' ? 'font-bold text-secondary-fixed' : ''}`} href="/en/">
              <span class="text-base">🇬🇧</span> <span>English</span>
            </a>
            <a class={`text-white text-sm font-medium hover:text-white/80 transition-colors py-2 px-2 flex items-center gap-3 ${currentLang === 'es' ? 'font-bold text-secondary-fixed' : ''}`} href="/es/">
              <span class="text-base">🇪🇸</span> <span>Español</span>
            </a>
          </div>
        </div>
      </div>

      <a href="#cta" class="bg-white text-primary px-5 md:px-6 py-2 md:py-2.5 rounded-full font-bold text-xs md:text-sm hover:bg-white/90 transition-all shadow-lg flex items-center gap-2 whitespace-nowrap cursor-pointer">
        {t('nav.demo')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </a>
    </div>
  </div>
</header>
