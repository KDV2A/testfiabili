---
// Block 5: Trust & Security (White)
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang?: keyof typeof languages;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const certifications = [
  { code: "27001", label: "ISO Security", colorClass: "text-primary border-primary/10" },
  { code: "27701", label: "ISO Privacy", colorClass: "text-secondary border-secondary/10" },
  { code: "42001", label: "ISO AI Mgmt", colorClass: "text-primary border-primary/10" },
  { code: "RGPD", label: "Compliance", colorClass: "text-secondary border-secondary/10" },
];
---

<section class="relative bg-white z-50 py-40 md:py-60 min-h-screen flex flex-col justify-center block-rounded-top shadow-[0_-25px_60px_rgba(0,0,0,0.08)] -mt-20 stacked-block" id="trust">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center stacked-content w-full">
    <h2 class="font-poppins font-semibold text-2xl sm:text-3xl md:text-4xl text-primary mb-16 tracking-tight gsap-reveal">{t('trust.title')}</h2>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 gsap-card-grid">
      {certifications.map((cert) => (
        <div class="flex flex-col items-center p-8 md:p-10 bg-surface-container-low rounded-3xl border border-outline-variant/10 group hover:bg-white hover:shadow-xl transition-all duration-300">
          <div class={`w-20 h-20 rounded-full bg-white shadow-inner flex items-center justify-center mb-6 border-2 ${cert.colorClass}`}>
            <span class={`font-poppins font-normal text-xl md:text-2xl ${cert.code === 'RGPD' || cert.code === '27701' ? 'text-secondary' : 'text-primary'}`}>{cert.code}</span>
          </div>
          <span class="font-poppins font-semibold text-sm md:text-base text-primary">{cert.label}</span>
        </div>
      ))}
    </div>

    <p class="mt-16 font-poppins font-normal text-base md:text-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed gsap-reveal">
      {t('trust.desc')}
    </p>
  </div>
</section>
