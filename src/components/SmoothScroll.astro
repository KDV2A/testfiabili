---
// SmoothScroll component with subtle card overlap dynamics & Grid spotlight for all white blocks
---

<script>
  import Lenis from 'lenis';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Initialize Lenis Smooth Scroll
  const lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    smoothWheel: true,
    touchMultiplier: 1.8,
  });

  lenis.on('scroll', ScrollTrigger.update);

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });

  gsap.ticker.lagSmoothing(0);

  // Handle internal anchor links smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const targetId = anchor.getAttribute('href');
      if (targetId && targetId !== '#') {
        const targetEl = document.querySelector(targetId);
        if (targetEl) {
          e.preventDefault();
          lenis.scrollTo(targetEl as HTMLElement, { offset: -80 });
        }
      }
    });
  });

  // Hero differential parallax between text block and 3D graphic
  const heroText = document.querySelector<HTMLElement>('.hero-text-block');
  const heroImage = document.querySelector<HTMLElement>('.hero-image-block');

  if (heroText && heroImage) {
    gsap.to(heroText, {
      y: -40,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      },
    });

    gsap.to(heroImage, {
      y: 50,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1.2,
      },
    });
  }

  // Interactive Cursor Grid Spotlight for all white blocks (Hero, Personas, Trust)
  const whiteSpotlightSections = document.querySelectorAll<HTMLElement>('section.bg-white');

  whiteSpotlightSections.forEach((section) => {
    const gridSpotlight = section.querySelector<HTMLElement>('[id$="-grid-spotlight"]');
    const spotlightGlow = section.querySelector<HTMLElement>('[id$="-spotlight-glow"]');

    if (gridSpotlight && spotlightGlow) {
      let mouseX = 0;
      let mouseY = 0;
      let ticking = false;

      section.addEventListener('mousemove', (e) => {
        const rect = section.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;

        if (!ticking) {
          requestAnimationFrame(() => {
            gridSpotlight.style.setProperty('--mouse-x', `${mouseX}px`);
            gridSpotlight.style.setProperty('--mouse-y', `${mouseY}px`);
            spotlightGlow.style.setProperty('--mouse-x', `${mouseX}px`);
            spotlightGlow.style.setProperty('--mouse-y', `${mouseY}px`);
            ticking = false;
          });
          ticking = true;
        }
      });
    }
  });

  // Subtle Card Overlap Dynamics on Scroll
  const stackedSections = document.querySelectorAll<HTMLElement>('.stacked-block');

  stackedSections.forEach((section, index) => {
    if (index > 0) {
      gsap.fromTo(
        section,
        { y: 35 },
        {
          y: 0,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'top 75%',
            scrub: 1,
          },
        }
      );
    }
  });

  // GSAP Scroll Reveal for Cards and Titles - Faster, responsive trigger
  const revealElements = document.querySelectorAll<HTMLElement>('.gsap-reveal');
  revealElements.forEach((el) => {
    gsap.fromTo(
      el,
      {
        y: 25,
        opacity: 0,
      },
      {
        y: 0,
        opacity: 1,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 92%',
          toggleActions: 'play none none reverse',
        },
      }
    );
  });

  // Stagger reveal for card grids - Snappy & fast
  const cardGrids = document.querySelectorAll<HTMLElement>('.gsap-card-grid');
  cardGrids.forEach((grid) => {
    const cards = grid.children;
    gsap.fromTo(
      cards,
      {
        y: 25,
        opacity: 0,
      },
      {
        y: 0,
        opacity: 1,
        duration: 0.5,
        stagger: 0.08,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: grid,
          start: 'top 88%',
          toggleActions: 'play none none reverse',
        },
      }
    );
  });

  // Floating Orbs parallax animation
  const orbs = document.querySelectorAll<HTMLElement>('.ai-orb');
  orbs.forEach((orb) => {
    gsap.to(orb, {
      y: -60,
      scale: 1.1,
      ease: 'none',
      scrollTrigger: {
        trigger: orb.parentElement || orb,
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1.2,
      },
    });
  });
</script>
