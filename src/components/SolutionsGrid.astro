---
// Block 2: Solutions Grid (Brand Blue)
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  lang?: keyof typeof languages;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const solutions = [
  {
    title: "MyVM",
    country: "France",
    descriptionKey: "solutions.myvm_desc",
    icon: "https://lh3.googleusercontent.com/aida/AP1WRLs-bw1FleF399Y6kfy8pPzbDxAGf8z9QFW1mytmIXBwfA5eHHl0IqIIe_PU9QKDI8txuZdDLPdNYOJJhk9G5Db5LT46_O3cMJETdVCb-AcZjfSSv08X_dc_BSUbwFfgIdxZ6FKwTwH5qJOzeOFkRsTmSVg6lStVlIG_IeWopREcZ606FyBSGkoh0_ORm22PLIExfDlhJ-nXPQ5-WXXADQuNstgMppo728VZTpMOQcM9eFTcYbx4rloowqY5",
    bgColor: "bg-white/10"
  },
  {
    title: "App Chantier",
    country: "Belgique",
    descriptionKey: "solutions.chantier_desc",
    icon: "https://lh3.googleusercontent.com/aida/AP1WRLvscBQBE8_Ep0BQYDgfhuQj2Hspx-DTDu06zAM4FZ2Do7yfy6Vq4UKg8smPg4VDmVy6okx7n1-GLtcjQTyKj43BYz8VCp8vDUPZsiy_US1c8pqVjT7vnFnCVYANvVDgAY8cjUJC1j0KDt_OZhO2yW-4rda0ox2Xf2Bqq3aEJy5w9jBu5X-sEcITSLEgjaqe5cql4JUMzfrWvxZfSdmw_tYRPRffINngyxJ7CoZRhQEcF7xcZlL-7VKniaDC",
    bgColor: "bg-secondary-container"
  },
  {
    title: "Expertis",
    country: "France",
    descriptionKey: "solutions.expertis_desc",
    icon: "https://lh3.googleusercontent.com/aida/AP1WRLuae_KXtvULUVz2V2fJbtt7QnOwOZUEQwqw14MsbE5V6o8iaPDtBQxq9UyrJwp0OhjIf7gxsnmcs7_H_bHNdX2oPhT2uO0c7q0JN2_lvqaG61nXDu0re85dcNpVHLdHcRTWN1UWMKsHhGKQ6QiV5lNL8mqKWJsPfihyLbwVRKykEFPVJcUlMrKkXvKUTG5aTFdklc1CzPs3hCkx2OOXGCyHZOGiAdNZ19ZkQdt35PPvncttstffjxwh5L0",
    bgColor: "bg-tertiary-container"
  }
];
---

<section class="relative bg-primary text-white z-20 py-40 md:py-60 min-h-screen flex flex-col justify-center block-rounded-top shadow-[0_-25px_60px_rgba(0,0,0,0.25)] -mt-20 stacked-block" id="solutions">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop stacked-content w-full">
    <div class="mb-16 flex flex-col md:flex-row items-start md:items-end justify-between gap-8 gsap-reveal">
      <div class="max-w-xl">
        <h2 class="font-poppins font-semibold text-2xl sm:text-3xl md:text-4xl text-white tracking-tight">{t('solutions.title')}</h2>
        <p class="font-poppins font-normal text-base md:text-lg text-white/70 mt-3 leading-relaxed">{t('solutions.subtitle')}</p>
      </div>
      <div class="flex gap-3">
        <button class="p-3 border border-white/20 rounded-full hover:bg-white/10 transition-all cursor-pointer" aria-label="Précédent">
          <span class="material-symbols-outlined text-white">chevron_left</span>
        </button>
        <button class="p-3 bg-white text-primary rounded-full hover:bg-white/90 transition-all shadow-lg cursor-pointer" aria-label="Suivant">
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 gsap-card-grid">
      {solutions.map((item) => (
        <div class="glass-card p-8 md:p-10 rounded-3xl flex flex-col h-full group hover:-translate-y-2 transition-all duration-500 bg-white/5 border-white/10 relative overflow-hidden">
          <div class={`w-14 h-14 rounded-2xl ${item.bgColor} flex items-center justify-center mb-6 shadow-md`}>
            <img alt={`${item.title} Icon`} class="w-10 h-10 object-contain" src={item.icon} />
          </div>
          <h3 class="font-poppins font-normal text-xl md:text-2xl text-white mb-2">{item.title}</h3>
          <p class="font-poppins font-semibold text-xs text-secondary-fixed uppercase tracking-widest mb-4">{item.country}</p>
          <p class="font-poppins font-normal text-base md:text-lg text-white/70 flex-grow leading-relaxed">{t(item.descriptionKey as any)}</p>
          <a class="mt-8 flex items-center gap-2 text-white font-poppins font-bold text-sm group-hover:gap-4 transition-all" href="#cta">
            {t('solutions.learn_more')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
