---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SolutionsGrid from '../components/SolutionsGrid.astro';
import Personas from '../components/Personas.astro';
import Expertise from '../components/Expertise.astro';
import TrustSecurity from '../components/TrustSecurity.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- Navigation Header -->
  <Header />

  <!-- Main Content Stacked Blocks -->
  <main class="relative">
    <!-- Block 1: Hero Section (White) -->
    <Hero />

    <!-- Block 2: Solutions Grid (Brand Blue) -->
    <SolutionsGrid />

    <!-- Block 3: Personas (White) -->
    <Personas />

    <!-- Block 4: Expertise (Brand Blue) -->
    <Expertise />

    <!-- Block 5: Trust & Security (White) -->
    <TrustSecurity />

    <!-- Block 6: Final CTA (Brand Blue) -->
    <CTA />
  </main>

  <!-- Footer Section -->
  <Footer />
</Layout>
